{
  "name": "@kungfu-tech/paper-kungfu-product-white-paper",
  "version": "0.1.0-alpha.8",
  "description": "Kungfu white paper on why long-running Agent work needs verified continuity beyond the session",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "README.md",
    "AGENTS.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE",
    "TRADEMARK.md",
    "ACCEPTABLE_USE.md",
    "PROVIDER_COMPLIANCE.md",
    "Makefile",
    ".buildchain/buildchain.toml",
    ".buildchain/contract-lock.json",
    ".buildchain/publication/publication-artifact.json",
    ".buildchain/publication/publication-artifact-passport.json",
    ".buildchain/publication/publication-registry.json",
    ".buildchain/publication/source.tar.gz",
    "_build/kungfu-white-paper.pdf",
    "docs",
    "paper",
    "release-impact.json",
    "scripts",
    "site"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./README.md": "./README.md",
    "./docs/*": "./docs/*",
    "./paper/main.tex": "./paper/main.tex",
    "./paper/references.bib": "./paper/references.bib",
    "./paper/sections/*.tex": "./paper/sections/*.tex",
    "./pdf": "./_build/kungfu-white-paper.pdf",
    "./buildchain/contract-lock.json": "./.buildchain/contract-lock.json",
    "./publication-artifact.json": "./.buildchain/publication/publication-artifact.json",
    "./publication-artifact-passport.json": "./.buildchain/publication/publication-artifact-passport.json",
    "./publication-registry.json": "./.buildchain/publication/publication-registry.json",
    "./source.tar.gz": "./.buildchain/publication/source.tar.gz",
    "./release-impact.json": "./release-impact.json",
    "./site/brand-site.json": "./site/brand-site.json",
    "./site/evidence-site.json": "./site/evidence-site.json",
    "./site/site-bundles.json": "./site/site-bundles.json",
    "./scripts/*.mjs": "./scripts/*.mjs"
  },
  "scripts": {
    "build": "node scripts/build-publication-artifact.mjs",
    "check": "node scripts/check.mjs",
    "publish:transaction": "node scripts/npm-publish-transaction.mjs",
    "update:site-bundles": "node scripts/update-site-bundles.mjs",
    "pdf": "make pdf"
  },
  "devDependencies": {
    "@kungfu-tech/buildchain": "^2.11.9"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kungfu-systems/paper-kungfu-product-white-paper.git"
  }
}
